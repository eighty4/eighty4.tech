---
import ProjectGroup from '../components/home/ProjectGroup.astro'
import { getRecentWriting } from '../content.api.ts'
import BaseLayout from '../layouts/BaseLayout.astro'

const writing = await getRecentWriting(3)
---

<BaseLayout>
    <div id="projects-header">
        <h2>Open source coding</h2>
        <p>My personal everyday tools are curated here.</p>
        <p>
            These libraries and tools are thoughtfully crafted with best
            principles to solve essential workflows.
        </p>
    </div>
    <ProjectGroup projectGroup="cloud" />
    <ProjectGroup projectGroup="cicd" />
    <ProjectGroup projectGroup="dx" />
    <ProjectGroup projectGroup="webdev" />
</BaseLayout>

<style>
    :root {
        --surface-bg: #e0e1e4;
    }

    #projects-header {
        width: 40rem;
        margin: 0 auto;
        margin-bottom: 2rem;

        & h2 {
            font-size: 2.2rem;
            margin-bottom: 2rem;
        }

        & p {
            color: #222;
            line-height: 1.4rem;
        }
    }
</style>
